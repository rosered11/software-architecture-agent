{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "D:/workspace/software-architecture-agent/.venv/Scripts/python.exe sync/hook_filter.py",
            "timeout": 120,
            "statusMessage": "Syncing KOS -> Notion...",
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true
  }
}
